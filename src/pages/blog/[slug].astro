---
import "../../styles/global.css";
import { getMarkdownToc, slugifyPath } from "../../utils/markdown-toc.js";

export function getStaticPaths() {
  const postModules = import.meta.glob("../../content/blog/*.md", { eager: true });
  const rawModules = import.meta.glob("../../content/blog/*.md", {
    eager: true,
    import: "default",
    query: "?raw"
  });

  return Object.entries(postModules).map(([path, post]) => ({
    params: { slug: post.frontmatter.slug ?? slugifyPath(post.frontmatter.title) },
    props: { post, markdownSource: rawModules[path] }
  }));
}

const { post, markdownSource } = Astro.props;
const { Content, frontmatter } = post;
const toc = getMarkdownToc(markdownSource);
const pageTitle = `${frontmatter.title} | BotNas Blog`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={frontmatter.excerpt} />
    <meta name="theme-color" content="#030b18" />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={frontmatter.excerpt} />
    <meta property="og:image" content={frontmatter.image} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{pageTitle}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bungee&family=Nunito:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body id="top" class="blog-post-body">
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="noise" aria-hidden="true"></div>
    <canvas class="signal-canvas" data-signal-canvas aria-hidden="true"></canvas>
    <div class="cursor-aura" aria-hidden="true"></div>

    <header class="site-header blog-post-headerbar" data-header>
      <a class="brand" href="/" aria-label="Go to portfolio homepage">
        <span class="brand-mark">BN</span>
        <span class="brand-copy">BotNas</span>
      </a>

      <nav class="nav blog-post-topnav" aria-label="Primary navigation">
        <a href="/#arsenal">Skills</a>
        <a href="/#credentials">Credentials</a>
        <a href="/#missions">Projects</a>
        <a href="/#blog" aria-current="page">Blog</a>
        <a href="/#contact">Contact</a>
      </nav>
    </header>

    <div class="blog-post-layout">
      <aside class="blog-sidebar" aria-label="Writeup navigation">
        <nav class="blog-sidebar__toc" aria-label="Writeup sections">
          <span>On this writeup</span>
          {toc.map((item) => (
            <a href={`#${item.slug}`}>{item.title}</a>
          ))}
        </nav>

        <div class="blog-sidebar__meta">
          <span>{frontmatter.category}</span>
          <strong>{new Date(frontmatter.date).toLocaleDateString("en", { month: "short", day: "numeric", year: "numeric" })}</strong>
        </div>

        <a class="blog-sidebar__back" href="/#blog">Back to blog</a>
      </aside>

      <main id="main" class="blog-post-main">
        <article class="blog-post-article">
          <header class="blog-post-header">
            <img class="blog-post-cover" src={frontmatter.image} alt={frontmatter.imageAlt} loading="eager" fetchpriority="high" decoding="async" />
            <p class="eyebrow">{frontmatter.category} / Writeup</p>
            <h1>{frontmatter.title}</h1>
            <p class="blog-post-lead">{frontmatter.excerpt}</p>
          </header>

          <div class="blog-post-content">
            <Content />
          </div>
        </article>
      </main>
    </div>

    <a class="back-to-top" href="#top" aria-label="Back to top">Top</a>
    <script src="../../scripts/site.js"></script>
  </body>
</html>
